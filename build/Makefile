.PHONY : src/main.cpp.i

src/main.s: src/main.cpp.s
.PHONY : src/main.s

# target to generate assembly for a file
src/main.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles\EGUI_app.dir\build.make CMakeFiles/EGUI_app.dir/src/main.cpp.s
.PHONY : src/main.cpp.s

